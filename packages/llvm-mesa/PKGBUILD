# Maintainer: Ardos OS Team
pkgname=llvm-mesa
pkgver=22.1.1
pkgrel=1
pkgdesc="LLVM privado para o Mesa no Ardos OS"
arch=('x86_64')
url="https://llvm.org/"
license=('Apache-2.0 WITH LLVM-exception')
makedepends=('cmake' 'ninja' 'zlib' 'zstd' 'libffi' 'python3')
depends=('glibc' 'libgcc' 'libstdc++' 'libffi')
options=('!lto' 'strip')

_source_base=https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver
source=($_source_base/llvm-project-$pkgver.src.tar.xz)
sha256sums=('9c6f37f6f5f68d38f435d25f770fc48c62d92b2412205767a16dac2c942f0c95')

prepare() {
  cd llvm-project-$pkgver.src/llvm
  mkdir -p build
}

build() {
  cd llvm-project-$pkgver.src/llvm/build

  # Forçando otimização de tamanho
  export CFLAGS="$CFLAGS -Os -g0"
  export CXXFLAGS="$CXXFLAGS -Os -g0"

  cmake .. -G Ninja \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr/lib/llvm-mesa \
    -DCMAKE_SKIP_RPATH=ON \
    -DLLVM_VERSION_SUFFIX="-mesa" \
    -DLLVM_BUILD_LLVM_DYLIB=ON \
    -DLLVM_LINK_LLVM_DYLIB=ON \
    -DLLVM_TARGETS_TO_BUILD="X86;AMDGPU" \
    -DLLVM_ENABLE_RTTI=ON \
    -DLLVM_ENABLE_ZLIB=OFF \
    -DLLVM_ENABLE_ZSTD=OFF \
    -DLLVM_ENABLE_PROJECTS="" \
    -DLLVM_INCLUDE_TESTS=OFF \
    -DLLVM_INCLUDE_UTILS=ON \
    -DLLVM_ENABLE_TERMINFO=OFF \
    -DLLVM_ENABLE_LIBXML2=OFF \
    -DLLVM_ENABLE_CURL=OFF \
    -DLLVM_ENABLE_SPHINX=OFF \
    -DLLVM_BUILD_DOCS=OFF

  ninja
}

package() {
  cd llvm-project-$pkgver.src/llvm/build
  DESTDIR="$pkgdir" ninja install

  # Removemos lixo (estáticas e arquivos de build do cmake)
  find "$pkgdir"/usr/lib/llvm-mesa -name "*.a" -delete
  rm -rf "$pkgdir"/usr/lib/llvm-mesa/lib/cmake
}