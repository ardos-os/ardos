package_vulkan-mesa-layers() {
  pkgdesc="Mesa's explicit Vulkan layers"
  depends=(
    glibc
    libgcc
    libpng
    libstdc++

    python
  )
  conflicts=(vulkan-mesa-layer)
  replaces=(vulkan-mesa-layer)

  mv vklayer/* "$pkgdir"

  install -Dm644 mesa-$_pkgver/docs/license.rst -t "$pkgdir/usr/share/licenses/$pkgname"
}

