# Used to generate the above table
_gencrates() {
  grep '^source_url' subprojects/*-rs.wrap | \
    sed -r 's|.*crates/([^/]+)/([0-9.]+)/download|\1 \2|' | \
    column -t -S 2 | sed 's/^/  /'
}

for _crate in "${!_crates[@]}"; do
  _ver="${_crates[$_crate]}"
  source+=(
    "$_crate-$_ver.tar.gz::https://crates.io/api/v1/crates/$_crate/$_ver/download"
  )
  sha256sums+=("SKIP")
done

prepare() {
  cd mesa-$_pkgver

  # Include package release in version string so Chromium invalidates
  # its GPU cache; otherwise it can cause pages to render incorrectly.
  # https://bugs.launchpad.net/ubuntu/+source/chromium-browser/+bug/2020604
  echo "$_pkgver-arch1.$pkgrel" >VERSION
}
patch_llvm_runtime() {
    local dir="$1"
    local llvm_dir="$2"

    find "$dir" -type f \( -name "*.so*" -o -executable \) | while read -r file; do
        file "$file" | grep -q ELF || continue

        needed=$(readelf -d "$file" 2>/dev/null | grep "(NEEDED)" || true)
        [[ -z "$needed" ]] && continue

        patched=false

        while read -r line; do
            lib=$(echo "$line" | sed -n 's/.*\[\(.*\)\].*/\1/p')
            [[ -z "$lib" ]] && continue

            case "$lib" in
                libLLVM.so.*)
                    new="${lib}-mesa"
                    ;;
                libLTO.so*)
                    new="${lib}-mesa"
                    ;;
                libRemarks.so*)
                    new="${lib}-mesa"
                    ;;
                libclang*.so*)
                    new="${lib}-mesa"
                    ;;
                *)
                    continue
                    ;;  
            esac

            if [[ -f "$llvm_dir/$new" ]]; then
                echo "Patch: $file :: $lib → $new"
                patchelf --replace-needed "$lib" "$new" "$file"
                patched=true
            else
                echo "WARNING: $new não existe em $llvm_dir"
            fi

        done <<< "$needed"

        if [[ "$patched" == true ]]; then
            patchelf --set-rpath "$llvm_dir:\$ORIGIN" "$file"
        fi
    done
}
build() {
  local meson_options=(
    -D b_ndebug=true

    -D platforms=wayland
    -D gbm=enabled
    -D egl=enabled
    -D glx=disabled

    -D gallium-drivers=all

    -D vulkan-drivers=all

    -D llvm=enabled
    -D shared-llvm=enabled
    -D intel-rt=enabled
    -D android-libbacktrace=disabled
    -D gallium-mediafoundation=disabled
    -D libunwind=disabled
    -D sysprof=false
    -D valgrind=disabled
    -D html-docs=disabled
    -D vulkan-layers=device-select,intel-nullhw,overlay,screenshot,anti-lag,vram-report-limit
    -D video-codecs=all
    -D xlib-lease=disabled

    -D gallium-rusticl-enable-drivers=asahi,freedreno,radeonsi
    -D gallium-rusticl=true
    -D vulkan-manifest-per-architecture=false


  )

  # --- TOOLCHAIN (use o clang/llvm do sistema para compilar os shaders) ---
  # Assegura que Meson/mesa_clc veem o llvm/clang do sistema (toolchain),
  # evitando que clang do sistema seja forçado a usar o llvm-mesa.
  export LLVM_CONFIG="/usr/bin/llvm-config"
  [[ -x "$LLVM_CONFIG" ]] || { echo "error: system llvm-config not found at $LLVM_CONFIG" >&2; return 1; }
  export CC="/usr/bin/clang"
  export CXX="/usr/bin/clang++"

  # --- pkgconfig: dar prioridade ao llvm-mesa pkgconfig para flags de link quando existir ---
  export PKG_CONFIG_PATH="/usr/lib/llvm-mesa/lib/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"

  # --- NÃO usar LD_PRELOAD nem sobrescrever PATH para llvm-mesa aqui ---
  # LD_PRELOAD causa ODR/ABI collisions com clang do sistema -> double free.
  # Removido: export PATH="/usr/lib/llvm-mesa/bin:$PATH"
  # Removido: export LD_PRELOAD="/usr/lib/llvm-mesa/lib/libLLVM.so"

  # Pedir ao linker que procure a runtime do llvm-mesa ao linkar bibliotecas finais.
  # Não exportamos LD_LIBRARY_PATH para evitar que ferramentas de build (mesa_clc, clang)
  # carreguem o llvm-mesa em execução — isto minimizará o risco de duas versões a serem
  # carregadas no mesmo processo.
  export LDFLAGS="-L/usr/lib/llvm-mesa/lib -Wl,-rpath,/usr/lib/llvm-mesa/lib $LDFLAGS"

  # Minimize debug output/size durante build
  CFLAGS+=" -g1"
  CXXFLAGS+=" -g1"

  # Meson package cache (igual ao teu fluxo)
  export MESON_PACKAGE_CACHE_DIR="$srcdir"

  # Configure & build
  arch-meson mesa-$_pkgver build "${meson_options[@]}"
  meson compile -C build
  
  patch_llvm_runtime "build" "/usr/lib/llvm-mesa/lib"
  # TODO: Patchar todos os .so pra usar as dlls do llvm em /usr/lib/llvm-mesa/lib/* usando patch_llvm_runtime
}

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    rm -rf "$d"
    mv -v "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_mesa() {
  depends=(
    expat
    glibc
    libdrm
    libelf
    libgcc
    libglvnd
    libstdc++
    llvm-mesa
    lm_sensors
    spirv-tools
    wayland
    zlib
    zstd
  )
  optdepends=("opengl-man-pages: for the OpenGL API man pages")
  provides=(
    "libva-mesa-driver=1:$pkgver-$pkgrel"
    "mesa-libgl=1:$pkgver-$pkgrel"
    libva-driver
    opengl-driver
  )
  conflicts=(
    'libva-mesa-driver<1:24.2.7-1'
    'mesa-libgl<17.0.1-2'
  )
  replaces=(
    'libva-mesa-driver<1:24.2.7-1'
    'mesa-libgl<17.0.1-2'
  )

  meson install -C build --destdir "$pkgdir" --no-rebuild
  (
    local libdir=usr/lib

    cd "$pkgdir"

    _pick vkd3d12 $libdir/libvulkan_dzn.so
    _pick vkd3d12 $libdir/libspirv_to_dxil.*
    _pick vkd3d12 usr/bin/spirv2dxil
    _pick vkd3d12 usr/share/vulkan/icd.d/dzn_icd.json



    _pick vkintel $libdir/libvulkan_intel{,_hasvk}.so
    _pick vkintel usr/share/vulkan/icd.d/intel{,_hasvk}_icd.json


    _pick vknvidia $libdir/libvulkan_nouveau.so
    _pick vknvidia usr/share/vulkan/icd.d/nouveau_icd.json

    _pick vkradeon $libdir/libvulkan_radeon.so
    _pick vkradeon usr/share/drirc.d/00-radv-defaults.conf
    _pick vkradeon usr/share/vulkan/icd.d/radeon_icd.json


    _pick vkvirtio $libdir/libvulkan_virtio.so
    _pick vkvirtio usr/share/vulkan/icd.d/virtio_icd.json

    _pick vkdevice $libdir/libVkLayer_MESA_anti_lag.so
    _pick vkdevice $libdir/libVkLayer_MESA_device_select.so
    _pick vkdevice usr/share/vulkan/implicit_layer.d

    _pick vklayer $libdir/libVkLayer_*.so
    _pick vklayer usr/bin/mesa-*-control.py
    _pick vklayer usr/share/vulkan/explicit_layer.d

  )

}

